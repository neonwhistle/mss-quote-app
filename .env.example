# --- Google Calendar (optional) ---
# Create a Google Cloud service account with Calendar API enabled, then share each
# van’s calendar with the service account email (“See all event details” or busier).
# Paste the full JSON key as a single line (escape newlines in private_key as \n).
#
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com",...}
#
# Each value is the calendar ID from Google Calendar settings (often …@group.calendar.google.com).
# GOOGLE_CALENDAR_ID_CART=
# GOOGLE_CALENDAR_ID_QUE=
# GOOGLE_CALENDAR_ID_SWEET_TOOTH=
